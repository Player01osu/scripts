#!/bin/bash
if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
    case "$1" in
        on) hyprsunset -g 48 -t 4900 &>/dev/null &!
            ;;
        off) killall hyprsunset
            ;;
        *) hyprsunset -g 48 -t 4900 &>/dev/null &!
            ;;
    esac
else
    case "$1" in
        on) redshift -P -O 5000 &>/dev/null
            ;;
        off) redshift -x &>/dev/null
            ;;
        *) redshift -P -O 5000 &>/dev/null
            ;;
    esac
fi

